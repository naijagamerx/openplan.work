{
    "name": "lazyman/tools",
    "description": "PHP Task Management System with encrypted JSON storage",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.66"
    },
    "autoload": {
        "classmap": ["includes/", "config.php"]
    },
    "autoload-dev": {
        "classmap": ["test/"]
    },
    "scripts": {
        "test": "php scripts/run_phpunit.php",
        "test-coverage": "php scripts/run_phpunit.php --coverage-html coverage",
        "qa:test": "php scripts/run_phpunit.php --no-coverage",
        "qa:stan": "phpstan analyze --no-progress --error-format=table",
        "qa:cs": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --ansi includes/TasksAPI.php test/AuthCoreTest.php test/DatabaseCoreTest.php test/TasksApiCoreTest.php test/Support/IsolatedDatabase.php",
        "qa:all": [
            "@qa:test",
            "@qa:stan",
            "@qa:cs"
        ]
    }
}
